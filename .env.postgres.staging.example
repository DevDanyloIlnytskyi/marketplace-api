# PostgreSQL POC staging — copy to .env.postgres.staging (gitignored). Do NOT commit secrets.
# Load with: node -r dotenv/config index.js dotenv_config_path=.env.postgres.staging

port=5000

# Force PostgreSQL for this POC session only (MySQL .env unchanged)
DB_DIALECT=postgres
TENANT_REGISTRY_PATH=config/clients.poc.postgres.json

# PostgreSQL connection
pg_host=127.0.0.1
pg_port=5432
pg_user=marketplace_pg
pg_password=change_me_poc_local
pg_superuser=postgres
pg_superuser_password=your_postgres_superuser_password

# MySQL source for migration scripts ONLY (test_bd — never autoleg_db)
mysql_host=127.0.0.1
mysql_port=3307
mysql_user=local
mysql_password=your_mysql_password
mysql_database=test_bd

jwtkey=your_jwt_secret_min_32_chars
