# Copy to .env and fill in local/production values. Do not commit .env.
# Variable names match api/sequelize.js (not DB_HOST-style aliases).

port=5000
host=127.0.0.1
db_port=3306
user=your_mysql_user
password=your_mysql_password
database=your_database_name
jwtkey=your_jwt_secret_min_32_chars

# Tenant media root. Required when NODE_ENV=production.
# Production canonical path: /opt/marketplace/storage
# Development: omit to use api/storage/ (repo-relative fallback)
# MARKETPLACE_STORAGE_ROOT=/opt/marketplace/storage
